{
  "compilerOptions": {
            "allowJs": true,
        "checkJs": false,
    "module": "commonjs",
    "target": "es2024",
    "outDir": "dist",
    "rootDir": ".",
    "verbatimModuleSyntax": false,
    "moduleDetection": "legacy",
    "strict": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "allowArbitraryExtensions": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true
  },
  "include": [
    "app.ts",
    "app/**/*"
  ],
  "exclude": [
    "node_modules",
    "dist"
  ]
}