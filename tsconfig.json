{
  "compilerOptions": {
    "module": "Node16",
    "target": "es2024",
    "moduleResolution": "node16",

    "verbatimModuleSyntax": false, 
    "moduleDetection": "legacy", 

    "strict": true,
    "skipLibCheck": true,

    "resolveJsonModule": true,
    "allowArbitraryExtensions": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true
  },
}
